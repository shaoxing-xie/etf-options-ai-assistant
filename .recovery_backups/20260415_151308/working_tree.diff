-    Returns:
-        tuple: (趋势方向, 趋势强度)
-    """
-    try:
-        if daily_df is None or daily_df.empty:
-            logger.warning(f"指数数据为空: {index_name}")
-            return "震荡", 0.5
-        
-        # 计算技术指标（MACD/RSI/MA）
