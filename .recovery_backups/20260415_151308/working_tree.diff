+        $form.style.display = isChart ? "flex" : "none";
+      }
+
+      for (const el of [$tabChart, $tabConfig]) {
+        el.addEventListener("click", () => setView(el.dataset.view));
+      }
+
+      function pickTime(row) {
+        const v =
+          row.time ??
+          row.timestamp ??
+          row.ts ??
+          row.datetime ??
+          row.date ??
+          row.trade_date ??
+          row.dt;
+        if (v == null) return null;
+        if (typeof v === "number") {
+          return v > 2_000_000_000 ? Math.floor(v / 1000) : Math.floor(v);
+        }
+        return toTs(v);
+      }
+
+      function num(row, k, fallback = null) {
+        const v = row?.[k];
+        if (v == null || v === "") return fallback;
+        const n = Number(v);
+        return Number.isFinite(n) ? n : fallback;
+      }
+
+      function toCandle(row) {
+        const time = pickTime(row);
+        if (!time) return null;
+        const open = num(row, "open", num(row, "o"));
+        const high = num(row, "high", num(row, "h"));
+        const low = num(row, "low", num(row, "l"));
+        const close = num(row, "close", num(row, "c"));
+        if ([open, high, low, close].some((x) => x == null)) return null;
+        return { time, open, high, low, close };
+      }
+
+      function toVolume(row) {
+        const time = pickTime(row);
+        if (!time) return null;
+        const value = num(row, "volume", num(row, "vol", 0)) ?? 0;
+        const close = num(row, "close", num(row, "c", 0)) ?? 0;
+        const open = num(row, "open", num(row, "o", close)) ?? close;
+        const color = close >= open ? "rgba(154, 209, 255, 0.55)" : "rgba(255, 154, 162, 0.55)";
+        return { time, value, color };
+      }
+
+      async function health() {
+        try {
+          const r = await jget("/api/health");
+          if (r?.success) {
+            if (chartInitError) {
+              setStatus(`API ready; chart unavailable: ${chartInitError}`);
+            } else {
+              setStatus("Ready. Try loading a symbol.");
+            }
+          }
+          else setStatus("API reachable, but unhealthy.");
+        } catch (e) {
+          setStatus("API not reachable.");
+        }
+      }
+
+      function currentWorkspaceState() {
+        return {
+          version: 1,
+          symbol: ($symbol.value || "").trim(),
+          data_type: ($dataType.value || "etf_daily").trim(),
+        };
+      }
+
+      async function loadOhlcv(symbol, dataType) {
+        const qs = new URLSearchParams({ symbol, data_type: dataType });
+        setStatus("Loading OHLCV…");
+        const r = await jget(`/api/ohlcv?${qs.toString()}`);
+        if (!r?.success) throw new Error(r?.message || "failed");
+        const rows = Array.isArray(r.data) ? r.data : [];
+        if (!hasChartReady()) {
+          throw new Error("chart renderer unavailable");
+        }
+        const candles = rows.map(toCandle).filter(Boolean);
+        const vols = rows.map(toVolume).filter(Boolean);
+        charts.series.candle.setData(candles);
+        charts.series.vol.setData(vols);
+        charts.series.second.setData(candles.map((c) => ({ time: c.time, value: c.close })));
+        setStatus(`Loaded ${symbol}: ${candles.length} bars.`);
+      }
+
+      async function refreshWorkspaces() {
+        const r = await jget("/api/workspaces");
+        const list = r?.success && Array.isArray(r.data) ? r.data : [];
+        const picked = $wsPick.value;
+        $wsPick.innerHTML = '<option value="">(none)</option>';
+        for (const item of list) {
+          const name = String(item?.name || "").trim();
+          if (!name) continue;
+          const opt = document.createElement("option");
+          opt.value = name;
+          opt.textContent = name;
+          $wsPick.appendChild(opt);
+        }
+        if (picked) $wsPick.value = picked;
+      }
+
+      async function loadWorkspace(name) {
+        const qs = new URLSearchParams({ name });
+        const r = await jget(`/api/workspace?${qs.toString()}`);
+        if (!r?.success) throw new Error(r?.message || "not found");
+        const state = r?.data?.state;
+        return state && typeof state === "object" ? state : {};
+      }
+
+      async function saveWorkspace(name, state) {
+        const r = await jpost("/api/workspace/save", { name, state });
+        if (!r?.success) throw new Error(r?.message || "save failed");
+      }
+
+      async function deleteWorkspace(name) {
+        const r = await jpost("/api/workspace/delete", { name });
+        if (!r?.success) throw new Error(r?.message || "delete failed");
+      }
+
+      async function loadAlertsYaml() {
+        const r = await jget("/api/alerts/config");
+        if (!r?.success) throw new Error(r?.message || "load alerts failed");
+        const text = String(r?.data?.text || "");
+        $wsJson.value = text;
+        return text;
+      }
+
+      async function saveAlertsYaml(text) {
+        const r = await jpost("/api/alerts/config/save", { text });
+        if (!r?.success) throw new Error(r?.message || "save alerts failed");
+      }
+
+      async function loadAlertReplay(limit = 80) {
+        const r = await jget(`/api/alerts/replay?limit=${encodeURIComponent(String(limit))}`);
+        if (!r?.success) throw new Error(r?.message || "load replay failed");
+        const rows = Array.isArray(r?.data) ? r.data : [];
+        $wsJson.value = JSON.stringify(rows, null, 2);
+        return rows;
+      }
+
+      $form.addEventListener("submit", async (ev) => {
+        ev.preventDefault();
+        const symbol = ($symbol.value || "").trim();
+        const dataType = ($dataType.value || "etf_daily").trim();
+        if (!symbol) return;
+        $load.disabled = true;
+        try {
+          await loadOhlcv(symbol, dataType);
+        } catch (e) {
+          setStatus(`Load failed: ${String(e?.message || e)}`);
+        } finally {
+          $load.disabled = false;
+        }
+      });
+
+      $wsRefresh.addEventListener("click", async () => {
+        try {
+          await refreshWorkspaces();
+          setStatus("Workspaces refreshed.");
+        } catch (e) {
+          setStatus(`Workspace refresh failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $wsExport.addEventListener("click", () => {
+        $wsJson.value = JSON.stringify(currentWorkspaceState(), null, 2);
+        setStatus("Exported current state to JSON.");
+      });
+
+      $wsApply.addEventListener("click", async () => {
+        try {
+          const obj = JSON.parse($wsJson.value || "{}");
+          const symbol = String(obj?.symbol || "").trim();
+          const dataType = String(obj?.data_type || "etf_daily").trim();
+          if (symbol) $symbol.value = symbol;
+          if (dataType) $dataType.value = dataType;
+          if (symbol) await loadOhlcv(symbol, dataType);
+          setStatus("Applied JSON to chart.");
+          setView("chart");
+        } catch (e) {
+          setStatus(`Apply JSON failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $wsLoad.addEventListener("click", async () => {
+        const name = ($wsPick.value || "").trim();
+        if (!name) return;
+        try {
+          setStatus(`Loading workspace "${name}"…`);
+          const state = await loadWorkspace(name);
+          $wsJson.value = JSON.stringify(state ?? {}, null, 2);
+          const symbol = String(state?.symbol || "").trim();
+          const dataType = String(state?.data_type || "etf_daily").trim();
+          if (symbol) $symbol.value = symbol;
+          if (dataType) $dataType.value = dataType;
+          if (symbol) await loadOhlcv(symbol, dataType);
+          setStatus(`Loaded workspace "${name}".`);
+          setView("chart");
+        } catch (e) {
+          setStatus(`Workspace load failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $wsSave.addEventListener("click", async () => {
+        const name = ($wsName.value || "").trim();
+        if (!name) return setStatus("Missing workspace name.");
+        try {
+          setStatus(`Saving workspace "${name}"…`);
+          await saveWorkspace(name, currentWorkspaceState());
+          await refreshWorkspaces();
+          $wsPick.value = name;
+          setStatus(`Saved workspace "${name}".`);
+        } catch (e) {
+          setStatus(`Workspace save failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $wsDelete.addEventListener("click", async () => {
+        const name = ($wsPick.value || "").trim();
+        if (!name) return;
+        try {
+          setStatus(`Deleting workspace "${name}"…`);
+          await deleteWorkspace(name);
+          await refreshWorkspaces();
+          $wsPick.value = "";
+          setStatus(`Deleted workspace "${name}".`);
+        } catch (e) {
+          setStatus(`Workspace delete failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $alertsLoad.addEventListener("click", async () => {
+        try {
+          setStatus("Loading alerts.yaml…");
+          await loadAlertsYaml();
+          setStatus("alerts.yaml loaded.");
+        } catch (e) {
+          setStatus(`alerts load failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $alertsSave.addEventListener("click", async () => {
+        try {
+          setStatus("Saving alerts.yaml…");
+          await saveAlertsYaml($wsJson.value || "");
+          setStatus("alerts.yaml saved.");
+        } catch (e) {
+          setStatus(`alerts save failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      $alertsReplay.addEventListener("click", async () => {
+        try {
+          setStatus("Loading alert replay…");
+          const rows = await loadAlertReplay(120);
+          setStatus(`Loaded replay events: ${rows.length}.`);
+        } catch (e) {
+          setStatus(`replay load failed: ${String(e?.message || e)}`);
+        }
+      });
+
+      setupChartsSafely();
+      await health();
+      try {
+        await refreshWorkspaces();
+      } catch {}
+      try {
+        await loadAlertsYaml();
+      } catch {}
+      if (hasChartReady()) {
+        try {
+          const symbol = ($symbol.value || "").trim();
+          const dataType = ($dataType.value || "etf_daily").trim();
+          if (symbol) await loadOhlcv(symbol, dataType);
+        } catch (e) {
+          setStatus(`Initial load failed: ${String(e?.message || e)}`);
+        }
+      }
+    </script>
   </body>
 </html>
