## Secrets / Tokens
#
# 统一原则（强制）：真实密钥只放在 ~/.openclaw/.env（并使用 KEY=VALUE）
# 该文件仅作为“可选覆盖/示例模板”，避免出现多份 .env 漂移导致的“工具找不到 key”问题。
# 如果你确实想为本项目单独覆盖某个值，请在此填入，但不要把真实密钥提交到 git。

# Feishu bot webhook (optional if using app)
FEISHU_WEBHOOK_URL=

# Feishu app credentials（机器人 / API 能力；与 webhook 文本通知可并存）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Tick providers（默认在 market_data.yaml 中关闭；启用时在此填入 ITICK_API_KEY / ALLTICK_API_KEY）
# ITICK_API_KEY=
# ALLTICK_API_KEY=

# Tushare
TUSHARE_TOKEN=

# LLM enhancer (OpenAI-compatible)
LLM_API_KEY=

# Tavily (for event-sentinel)
TAVILY_API_KEY=

# Financial Modeling Prep — 全球指数最新快照（data_sources.global_index.latest / tool_fetch_global_index_spot）
FMP_API_KEY=
FMP_API_KEY_BACKUP=
## ETF project env example (do not commit real values)
## Rule:
## - ETF_*: business/project-level variables
## - OPENCLAW_*: platform-level variables

# ------------------------------
# ETF project-level variables
# ------------------------------
ETF_APP_ENV=dev
ETF_LOG_LEVEL=INFO
ETF_TIMEZONE=Asia/Shanghai

ETF_TUSHARE_TOKEN=
ETF_TAVILY_API_KEY=
# Tavily 多 Key 轮换（与 plugins.utils.tavily_client / 盘前 policy_news 等同源）：
# TAVILY_API_KEYS=key1,key2  或  TAVILY_API_KEY=… + TAVILY_API_KEY_2=…
TAVILY_API_KEYS=
TAVILY_API_KEY=
TAVILY_API_KEY_2=
ETF_LLM_API_KEY=

# ------------------------------
# OpenClaw platform-level variables
# ------------------------------
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

OPENCLAW_DINGTALK_CLIENT_ID=
OPENCLAW_DINGTALK_CLIENT_SECRET=
OPENCLAW_DINGTALK_CORP_ID=
OPENCLAW_DINGTALK_AGENT_ID=

OPENCLAW_FEISHU_APP_ID=
OPENCLAW_FEISHU_APP_SECRET=

OPENCLAW_OPENROUTER_API_KEY=
OPENCLAW_TAVILY_API_KEY=

# Financial Modeling Prep — 全球指数最新快照（tool_fetch_global_index_spot / data_sources.global_index.latest）
# 复制到项目根 .env 或写入 ~/.openclaw/.env（Gateway）；勿提交真实密钥
FMP_API_KEY=
FMP_API_KEY_BACKUP=
# 可选别名，与部分文档一致（解析顺序在主 key、backup 之后）
# FINANCIAL_MODELING_PREP_API_KEY=

