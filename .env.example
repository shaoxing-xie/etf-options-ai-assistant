## ETF project env example (do not commit real values)
## Rule:
## - ETF_*: business/project-level variables
## - OPENCLAW_*: platform-level variables

# ------------------------------
# ETF project-level variables
# ------------------------------
ETF_APP_ENV=dev
ETF_LOG_LEVEL=INFO
ETF_TIMEZONE=Asia/Shanghai

ETF_TUSHARE_TOKEN=
ETF_ITICK_API_KEY=
ETF_ALLTICK_API_KEY=
ETF_TAVILY_API_KEY=
# Tavily 多 Key 轮换（与 plugins.utils.tavily_client / 盘前 policy_news 等同源）：
# TAVILY_API_KEYS=key1,key2  或  TAVILY_API_KEY=… + TAVILY_API_KEY_2=…
TAVILY_API_KEYS=
TAVILY_API_KEY=
TAVILY_API_KEY_2=
ETF_LLM_API_KEY=

ETF_FEISHU_WEBHOOK_URL=
ETF_FEISHU_APP_ID=
ETF_FEISHU_APP_SECRET=
ETF_FEISHU_ROOT_FOLDER_TOKEN=

# ------------------------------
# OpenClaw platform-level variables
# ------------------------------
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

OPENCLAW_DINGTALK_CLIENT_ID=
OPENCLAW_DINGTALK_CLIENT_SECRET=
OPENCLAW_DINGTALK_CORP_ID=
OPENCLAW_DINGTALK_AGENT_ID=

OPENCLAW_FEISHU_APP_ID=
OPENCLAW_FEISHU_APP_SECRET=

OPENCLAW_OPENROUTER_API_KEY=
OPENCLAW_TAVILY_API_KEY=

# Financial Modeling Prep — 全球指数最新快照（tool_fetch_global_index_spot / data_sources.global_index.latest）
# 复制到项目根 .env 或写入 ~/.openclaw/.env（Gateway）；勿提交真实密钥
FMP_API_KEY=
FMP_API_KEY_BACKUP=
# 可选别名，与部分文档一致（解析顺序在主 key、backup 之后）
# FINANCIAL_MODELING_PREP_API_KEY=

